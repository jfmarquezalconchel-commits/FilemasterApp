<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE hibernate-configuration PUBLIC
        "-//Hibernate/Hibernate Configuration DTD 3.0//EN"
        "http://www.hibernate.org/dtd/hibernate-configuration-3.0.dtd">

<hibernate-configuration>
    <session-factory>

        <!-- 🔌 Conexión a la base de datos -->
        <property name="hibernate.connection.driver_class">com.mysql.cj.jdbc.Driver</property>
        <property name="hibernate.connection.url">jdbc:mysql://localhost:3306/filemaster</property>
        <property name="hibernate.connection.username">developer</property>
        <property name="hibernate.connection.password">1234</property>

        <!-- ⚙️ Dialecto -->
        <property name="hibernate.dialect">org.hibernate.dialect.MySQLDialect</property>

        <!-- 🧠 Opciones útiles -->
        <property name="hibernate.show_sql">true</property>
        <property name="hibernate.format_sql">true</property>

        <!-- ⚠️ Gestión de esquema -->
        <property name="hibernate.hbm2ddl.auto">update</property>
        <!-- opciones: validate | update | create | create-drop -->

        <!-- 📦 Entidades -->
        <mapping class="com.filemasterapp.FilemasterApp.Model.FileSystem"/>
        <mapping class="com.filemasterapp.FilemasterApp.Model.File"/>
        <!-- añade aquí más entidades -->

    </session-factory>
</hibernate-configuration>